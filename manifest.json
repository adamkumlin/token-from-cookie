{
  "name": "get-token-from-cookie",
  "description": "Get your token from a given cookie",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_icon": "icon.png",
    "default_popup": "hello.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://app.salesys.se/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.salesys.se/*"],
      "js": ["scripts/injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://app.salesys.se/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "scripting"
  ]
}